# ─────────────────────────────────────────────────────────────
# Supabase — copia este archivo a .env.local y completa los valores
# (Project Settings → API en https://app.supabase.com)
# ─────────────────────────────────────────────────────────────

# URL del proyecto (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública anónima (segura para el navegador, protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (SOLO servidor — nunca exponer al cliente).
# Se usa en tareas administrativas / generación de reportes.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio (para redirects de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
